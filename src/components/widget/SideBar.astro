---
import type { MarkdownHeading } from "astro";
import Announcement from "./Announcement.astro";
import Calendar from "./Calendar.astro";
import Categories from "./Categories.astro";
import Profile from "./Profile.astro";
import SidebarTOC from "./SidebarTOC.astro";
import Tag from "./Tags.astro";
import { url } from "../../utils/url-utils";

interface Props {
	class?: string;
	headings?: MarkdownHeading[];
	side?: "left" | "right";
}

const { side, headings } = Astro.props;
const className = Astro.props.class;
const isPostsRoute = Astro.url.pathname.startsWith(url("/posts/"));
---
{side === "right" ? (
<div class:list={[className, "w-full"]}>
    <div class="sticky top-4 flex flex-col gap-4">
        {isPostsRoute ? (
            <SidebarTOC class="onload-animation" />
        ) : (
            <>
                <Announcement class="onload-animation" />
                <Calendar class="onload-animation" />
            </>
        )}
    </div>
</div>
) : (
<div id="sidebar" class:list={[className, "w-full"]}>
    <div class="flex flex-col w-full gap-4 mb-4">
        <Profile></Profile>
    </div>
    <div id="sidebar-sticky" class="transition-all duration-700 flex flex-col w-full gap-4 top-4 sticky top-4">
        <Categories class="onload-animation" style="animation-delay: 150ms"></Categories>
        <Tag class="onload-animation" style="animation-delay: 200ms"></Tag>
    </div>
</div>
)}
