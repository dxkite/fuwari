---
import MainGridLayout from "../layouts/MainGridLayout.astro";

interface FriendLink {
	id: string;
	title: string;
	imgUrl: string;
	desc: string;
	siteUrl: string;
	tags: string[];
	weight: number;
	enabled: boolean;
}

const apiBase = (
	(typeof process !== "undefined" ? process.env?.API_BASE_URL : undefined) ??
	"http://127.0.0.1:8080"
).replace(/\/$/, "");

let items: FriendLink[] = [];
try {
	const resp = await fetch(`${apiBase}/api/v1/friends`);
	const json = await resp.json();
	items = ((json?.data?.items ?? []) as FriendLink[])
		.filter((f) => f.enabled)
		.sort((a, b) => b.weight - a.weight);
} catch (e) {
	console.error("Failed to fetch friends:", e);
}

const allTags = [...new Set(items.flatMap((item) => item.tags || []))].sort();
---

<MainGridLayout title="友链" description="朋友们的博客与站点">
	<div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
		<div class="card-base z-10 px-9 py-6 relative w-full">
			<div class="mb-4">
				<div class="text-3xl font-bold text-neutral-900 dark:text-neutral-100 mb-2">
					友链
				</div>
				<p class="text-base text-neutral-600 dark:text-neutral-400">
					朋友们的博客与站点
				</p>
			</div>

			{
				items.length > 0 && (
					<friend-filter class="block mb-6">
						<div class="relative mb-3">
							<input
								type="text"
								data-search
								placeholder="搜索友链..."
								class="w-full px-4 py-2.5 rounded-xl border border-[var(--line-divider)] bg-transparent text-neutral-900 dark:text-neutral-100 placeholder-neutral-400 dark:placeholder-neutral-500 outline-none text-sm"
							/>
						</div>
						<div class="flex flex-wrap gap-2">
							<button
								data-tag="all"
								class="friends-tag-btn active px-3 py-1.5 rounded-lg bg-[var(--primary)] text-white text-sm font-medium"
							>
								全部
							</button>
							{allTags.map((tag) => (
								<button
									data-tag={tag}
									class="friends-tag-btn px-3 py-1.5 rounded-lg bg-[var(--btn-regular-bg)] text-[var(--btn-content)] hover:bg-[var(--btn-regular-bg-hover)] text-sm font-medium"
								>
									{tag}
								</button>
							))}
						</div>
					</friend-filter>
				)
			}

			<div class="friends-grid my-4">
				{
					items.length === 0 && (
						<div class="col-span-full flex flex-col items-center justify-center py-12 text-neutral-400 dark:text-neutral-500">
							<div class="text-4xl mb-3">👥</div>
							<div class="text-sm">暂无友链</div>
						</div>
					)
				}
				{
					items.map((item) => (
						<a
							href={item.siteUrl}
							target="_blank"
							rel="noopener noreferrer"
							data-tags={item.tags?.join(",")}
							class="friend-card group flex items-center gap-3 p-2.5 rounded-xl border border-[var(--line-divider)] hover:border-[var(--primary)] transition-all duration-300 hover:shadow-lg relative overflow-hidden"
						>
							<div class="absolute inset-0 bg-[var(--primary)] opacity-0 group-hover:opacity-5 transition-opacity duration-300 pointer-events-none" />
							<div class="relative w-16 h-16 shrink-0 rounded-xl overflow-hidden bg-zinc-100 dark:bg-zinc-800 border border-black/5 dark:border-white/5 group-hover:scale-105 transition-transform duration-300">
								{item.imgUrl ? (
									<img
										src={item.imgUrl}
										alt={item.title}
										class="w-full h-full object-cover"
									/>
								) : (
									<div class="w-full h-full flex items-center justify-center text-2xl">
										🔗
									</div>
								)}
							</div>
							<div class="grow min-w-0 flex flex-col justify-center gap-0.5">
								<div class="font-bold text-base text-neutral-900 dark:text-neutral-100 group-hover:text-[var(--primary)] transition-colors truncate">
									{item.title}
								</div>
								<div
									class="text-sm text-neutral-500 dark:text-neutral-400 line-clamp-1"
									title={item.desc}
								>
									{item.desc}
								</div>
								<div class="flex flex-wrap gap-1 mt-1">
									{item.tags && item.tags.length > 0
										? item.tags
												.slice(0, 3)
												.map((tag) => (
													<span class="text-[0.65rem] px-1.5 py-0.5 rounded bg-neutral-100 dark:bg-neutral-800 text-neutral-500 dark:text-neutral-400">
														{tag}
													</span>
												))
										: null}
								</div>
							</div>
						</a>
					))
				}
			</div>

			<div
				class="friends-empty hidden flex-col items-center justify-center py-12 text-neutral-400 dark:text-neutral-500"
			>
				<div class="text-4xl mb-3">🔍</div>
				<div class="text-sm">没有匹配的友链</div>
			</div>
		</div>
	</div>

	<script is:inline>
		if (!customElements.get("friend-filter")) {
			class FriendFilter extends HTMLElement {
				selectedTag = "all";

				connectedCallback() {
					this.addEventListener("click", this._handleClick.bind(this));
					const input = this.querySelector("[data-search]");
					if (input) input.addEventListener("input", () => this._applyFilters());
				}

				disconnectedCallback() {
					this.removeEventListener("click", this._handleClick.bind(this));
				}

				_handleClick(e) {
					const button = e.target.closest("button");
					if (!button || !button.dataset.tag) return;
					this.selectedTag = button.dataset.tag;
					this.querySelectorAll(".friends-tag-btn").forEach((f) => {
						if (f === button) {
							f.classList.remove("bg-[var(--btn-regular-bg)]", "text-[var(--btn-content)]");
							f.classList.add("active", "bg-[var(--primary)]", "text-white");
						} else {
							f.classList.remove("active", "bg-[var(--primary)]", "text-white");
							f.classList.add("bg-[var(--btn-regular-bg)]", "text-[var(--btn-content)]");
						}
					});
					this._applyFilters();
				}

				_applyFilters() {
					const container = this.closest(".card-base");
					if (!container) return;
					const input = this.querySelector("[data-search]");
					const query = (input?.value || "").toLowerCase().trim();
					const cards = container.querySelectorAll(".friend-card");
					let hasVisible = false;
					cards.forEach((card) => {
						const tags = (card.dataset.tags || "").split(",").filter(Boolean);
						const name = (card.querySelector(".font-bold")?.textContent || "").toLowerCase();
						const desc = (card.querySelector(".line-clamp-1")?.textContent || "").toLowerCase();
						const tagMatch = this.selectedTag === "all" || tags.includes(this.selectedTag);
						const searchMatch =
							!query ||
							name.includes(query) ||
							desc.includes(query) ||
							tags.some((t) => t.toLowerCase().includes(query));
						card.style.display = tagMatch && searchMatch ? "" : "none";
						if (tagMatch && searchMatch) hasVisible = true;
					});
					const emptyEl = container.querySelector(".friends-empty");
					if (emptyEl) {
						emptyEl.classList.toggle("hidden", hasVisible);
						emptyEl.classList.toggle("flex", !hasVisible);
					}
				}
			}
			customElements.define("friend-filter", FriendFilter);
		}
	</script>

	<style is:global>
		.friends-grid {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
			gap: 0.75rem;
		}
	</style>
</MainGridLayout>
